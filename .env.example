# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka-35eadd43-chanuka-6c78.k.aivencloud.com:18468
KAFKA_USERNAME=avnadmin
KAFKA_PASSWORD=your_password_here
KAFKA_CLIENT_ID=crypto-service
KAFKA_SSL_REJECT_UNAUTHORIZED=true
KAFKA_CA_CERT=path/to/ca.pem

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
CORS_ORIGIN=*

# Producer Configuration
KAFKA_TOPIC=crypto-prices
PRODUCER_INTERVAL_MS=5000
KAFKA_PARTITIONER=LegacyPartitioner

# Consumer Configuration
KAFKA_CONSUMER_GROUP_ID=crypto-consumer-group
KAFKA_CONSUMER_FROM_BEGINNING=false

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring Configuration
MONITORING_ENABLED=true
METRICS_PORT=9090

# Environment
NODE_ENV=production
